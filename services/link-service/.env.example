# MongoDB connection string used by the app and the seed script
MONGO_URI=mongodb://localhost:27017/portlhub_links

# Secret used to verify JWTs — MUST match user-service's JWT_SECRET, since
# this service verifies tokens that user-service issued.
JWT_SECRET=change-me-to-a-long-random-secret

# HTTP port the service listens on — use a different port from user-service
PORT=4001
