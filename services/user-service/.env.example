# PostgreSQL connection string used by both the app and drizzle-kit
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portlhub_users

# Secret used to sign JWTs — use a long, random value in production
JWT_SECRET=change-me-to-a-long-random-secret

# JWT lifetime — accepts vercel/ms style strings (e.g. 15m, 1h, 7d)
JWT_EXPIRES_IN=7d

# HTTP port the service listens on
PORT=4000
